<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="56dp"
    android:layout_height="56dp"
    android:layout_margin="6dp"
    android:id="@+id/lens_item_container">

    <!-- Inner circle representing the lens button -->
    <FrameLayout
        android:id="@+id/lens_circle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/glass_rec_pill"
        android:backgroundTint="#4D000000">

        <!-- Emoji representing the lens -->
        <TextView
            android:id="@+id/lens_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🐶"
            android:textSize="24sp" />

    </FrameLayout>

</FrameLayout>
