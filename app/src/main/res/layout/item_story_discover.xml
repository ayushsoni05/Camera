<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:layout_margin="6dp"
    android:background="@drawable/glass_rec_pill"
    android:backgroundTint="#2E2E3E">

    <!-- Card Background Color/Tint overlay -->
    <View
        android:id="@+id/discover_card_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/glass_rec_pill" />

    <!-- Dark shadow gradient overlay at the bottom for text readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="bottom"
        android:background="@drawable/discover_bottom_shadow" />

    <!-- Title and Subtitle Text Block -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/discover_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="Discover Title" />

        <TextView
            android:id="@+id/discover_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Discover Subtitle" />

    </LinearLayout>

</FrameLayout>
