<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:clickable="true"
    android:focusable="true">

    <!-- Top Navigation Bar -->
    <ImageButton
        android:id="@+id/btn_signup_password_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        app:tint="#111119"
        android:contentDescription="Back" />

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_below="@id/btn_signup_password_back"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set a password"
            android:textColor="#111119"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your password should be at least 8 characters long."
            android:textColor="#808080"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- Password Input Field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="#808080"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="40dp">

                <EditText
                    android:id="@+id/et_signup_password"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:inputType="textPassword"
                    android:textColor="#111119"
                    android:textSize="16sp"
                    android:maxLines="1"
                    android:layout_toStartOf="@id/btn_signup_pw_toggle"
                    android:importantForAutofill="no" />

                <ImageButton
                    android:id="@+id/btn_signup_pw_toggle"
                    android:layout_width="40dp"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="#808080"
                    android:contentDescription="Toggle Password" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="#D0D0D8" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Submit Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_signup_password_next"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="32dp"
        android:text="Continue"
        android:textColor="#F8F9FA"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="27dp"
        android:backgroundTint="#00A4FF"
        android:elevation="4dp" />
</RelativeLayout>
