<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:clickable="true"
    android:focusable="true">

    <!-- Top Navigation Bar -->
    <ImageButton
        android:id="@+id/btn_signup_email_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        app:tint="#111119"
        android:contentDescription="Back" />

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_below="@id/btn_signup_email_back"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What's your email?"
            android:textColor="#111119"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We will use this to secure your account."
            android:textColor="#808080"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- Email Input Field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL ADDRESS"
                android:textColor="#808080"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <EditText
                android:id="@+id/et_signup_email"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:inputType="textEmailAddress"
                android:textColor="#111119"
                android:textSize="16sp"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="#D0D0D8" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Submit Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_signup_email_next"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="32dp"
        android:text="Submit"
        android:textColor="#F8F9FA"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="27dp"
        android:backgroundTint="#00A4FF"
        android:elevation="4dp" />
</RelativeLayout>
