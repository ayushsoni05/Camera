<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom Nav background: solid #12161F with top border separator -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF12161F" />
        </shape>
    </item>
    <!-- Top border line -->
    <item android:bottom="71dp">
        <shape android:shape="rectangle">
            <solid android:color="#1AFFFFFF" />
        </shape>
    </item>
</layer-list>
